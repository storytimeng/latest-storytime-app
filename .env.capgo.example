# =============================================================================
# .env.capgo.example
#
# Copy this to `.env.capgo.local` and fill in the real values. Both files
# are gitignored. The `capgo-deploy.mjs` script auto-loads them.
#
#   cp .env.capgo.example .env.capgo.local
#   # then edit .env.capgo.local
# =============================================================================

# ── Required ────────────────────────────────────────────────────────────────

# Mint one with: scripts/rotate-capgo-key.sql (run in Supabase SQL editor).
CAPGO_API_KEY=<paste-new-key-here>

# Your self-hosted Capgo API host. Same as in the GitHub Actions secret.
CAPGO_API_HOST=https://xssneissyscmaibeoojq.supabase.co/functions/v1

# ── Optional (defaults are set in scripts/capgo-deploy.mjs) ────────────────

# Supabase project that backs the Capgo backend.
# CAPGO_SUPA_HOST=https://xssneissyscmaibeoojq.supabase.co

# Supabase publishable anon key. Already in capacitor.config.ts.
# CAPGO_SUPA_ANON=sb_publishable_wMAICJbQ1OYszQudDGg3sA_rMm1jFpC

# Override the channel (otherwise: dev for `capgo:dev`, production for `capgo:prod`).
# CAPGO_CHANNEL=dev

# Pin a bundle version. Otherwise the script makes one like
# 0.0.1-20260712021530 from the current timestamp.
# CAPGO_BUNDLE=0.0.2-some-tag

# Public backend URL. The script falls back to https://back.storytime.ng if
# this is unset.
# NEXT_PUBLIC_API_URL=https://storytime-backend-1-0.onrender.com
